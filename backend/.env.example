# Copy this file to .env and adjust values.

# Server
PORT=5000

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/xebia-user-management
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/xebia-user-management
MONGO_URI=mongodb://127.0.0.1:27017/xebia-user-management

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed admin (used by `npm run seed:admin`)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PHONE=0000000000
SEED_ADMIN_PASSWORD=admin123
